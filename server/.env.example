# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# DeepSeek — 仅作模板，不要填真实 Key（会提交 Git）
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# CORS（前端开发地址）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 请求限流（slowapi 格式；开发可设 RATE_LIMIT_ENABLED=false）
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT=10/minute

# 敏感词（逗号分隔，忽略大小写子串匹配）
SENSITIVE_WORDS=违禁,暴力,赌博,色情,毒品

# 聊天入参长度上限
CHAT_MESSAGE_MAX_LENGTH=4000
CHAT_SYSTEM_MAX_LENGTH=2000

# 多轮对话 history 最多条数（不含当前 message）
CHAT_HISTORY_MAX_MESSAGES=20

# LLM 参数
CHAT_DEFAULT_TEMPERATURE=0.7
CHAT_ALLOWED_MODELS=deepseek-v4-flash,deepseek-chat,deepseek-reasoner

# --- Phase 2 RAG（知识库问答）---
# RAG_SQLITE_PATH=./data/rag.db
# RAG_CHROMA_DIR=./data/chroma
# RAG_UPLOAD_DIR=./data/uploads
BGE_M3_MODEL=BAAI/bge-m3
BGE_M3_USE_FP16=false
BGE_M3_MAX_LENGTH=512
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_DEFAULT_TOP_K=5
RAG_MAX_TOP_K=10
RAG_ALLOWED_EXTENSIONS=.txt,.md,.markdown,.pdf,.doc,.docx,.xlsx,.xls,.pptx,.ppt,.png,.jpg,.jpeg,.webp
RAG_MAX_UPLOAD_BYTES=5242880
RAG_OCR_ENABLED=true
RAG_OCR_PDF_ZOOM=2
RAG_OCR_MAX_PDF_PAGES=50
RATE_LIMIT_RAG=10/minute
# 国内下载 HuggingFace 模型可选镜像
HF_ENDPOINT=https://hf-mirror.com

